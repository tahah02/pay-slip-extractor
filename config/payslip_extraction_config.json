{
  "payslip": {
    "name": {
      "keywords": ["name", "nama", "employee name", "nama pegawai", "employee"],
      "pattern": null,
      "required": true,
      "fallback_patterns": [
        "(?:Name|Nama|Employee Name|Nama Pegawai)[:\\s]*([A-Za-z][A-Za-z\\s]+)",
        "^([A-Z][A-Z\\s]{10,})$"
      ]
    },
    "id_number": {
      "keywords": ["id", "nric", "no. k/p", "no k/p", "employee id", "identification"],
      "pattern": "\\d{6}-\\d{2}-\\d{4}",
      "required": true,
      "fallback_patterns": [
        "(?:No\\.?\\s*K/P|NRIC|ID Number|Employee ID)[:\\s]*(\\d{6}-\\d{2}-\\d{4})",
        "(\\d{6}-\\d{2}-\\d{4})"
      ]
    },
    "gross_income": {
      "keywords": ["gross", "gross income", "gross salary", "total income", "jumlah pendapatan", "gaji pokok", "gaji kasar"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": true,
      "fallback_patterns": [
        "(?:Gross Income|Jumlah Pendapatan|Gaji Pokok|Gaji Kasar|Total Income)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ],
      "exclusion_keywords": ["peratus", "bercukai", "rate", "kadar", "%", "percent"]
    },
    "net_income": {
      "keywords": ["net", "net income", "take home", "net salary", "gaji bersih"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": true,
      "fallback_patterns": [
        "(?:Net Income|Gaji Bersih|Take Home|Net Salary)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ],
      "exclusion_keywords": ["peratus", "bercukai", "rate", "kadar", "%", "percent"]
    },
    "total_deduction": {
      "keywords": ["deduction", "total deduction", "total deductions", "jumlah potongan"],
      "pattern": "[\\d,]+\\.\\d{2}",
      "required": true,
      "fallback_patterns": [
        "(?:Total Deduction|Jumlah Potongan|Total Deductions|Deduction)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ],
      "deduction_item_patterns": [
        "(?:EPF|KWSP|SOCSO|PERKESO|PCB|Zakat|Insurance|Insurans)[:\\s]*(?:RM)?[:\\s]*([\\d,]+\\.?\\d*)"
      ]
    },
    "month_year": {
      "keywords": ["month", "period", "date", "month/year", "bulan"],
      "pattern": "\\d{2}/\\d{4}",
      "required": true,
      "fallback_patterns": [
        "(?:Month|Bulan|Period|Month/Year)[:\\s]*(\\d{2}/\\d{4})",
        "(\\d{2}/\\d{4})"
      ]
    }
  }
}
